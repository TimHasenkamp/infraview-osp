# Domain — your public hostname (no https://)
DOMAIN=monitor.example.com

# Required for Traefik — Let's Encrypt notification email
ACME_EMAIL=admin@example.com

# Security — generate with: openssl rand -hex 32 / openssl rand -hex 16
JWT_SECRET_KEY=change-me-jwt
AGENT_API_KEY=change-me-agent

# Display name for this server in the dashboard (e.g. "web-01", "monitoring")
INFRAVIEW_AGENT_ID=my-server

# Optional — email alerting via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
