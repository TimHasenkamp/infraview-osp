# ─── Required ────────────────────────────────────────────────────────────────

# WebSocket URL of your InfraView backend.
# Use wss:// for HTTPS-backed backends, ws:// for plain HTTP.
INFRAVIEW_BACKEND_URL=wss://monitor.example.com/ws/agent

# API key generated in the InfraView dashboard under Settings → Agent Keys.
INFRAVIEW_API_KEY=your-agent-api-key-here

# ─── Optional ────────────────────────────────────────────────────────────────

# Unique name shown in the dashboard for this server.
# Defaults to the container's hostname if left empty.
INFRAVIEW_AGENT_ID=my-server-name

# Metric collection interval in seconds (default: 5).
INFRAVIEW_INTERVAL=5

# Disk path to report usage for (default: /).
INFRAVIEW_DISK_PATH=/
