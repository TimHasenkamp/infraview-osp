# Backend
DATABASE_URL=sqlite+aiosqlite:///data/infraview.db

# SMTP (optional, for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=

# Agent
INFRAVIEW_BACKEND_URL=ws://localhost:8000/ws/agent
INFRAVIEW_AGENT_ID=
INFRAVIEW_INTERVAL=5
INFRAVIEW_DISK_PATH=/

# Frontend
NEXT_PUBLIC_API_URL=/api/proxy
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/dashboard
BACKEND_URL=http://localhost:8000
